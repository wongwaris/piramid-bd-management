# PIRAMID BD Management — Environment Variables
# Copy to your Vercel/Netlify project settings (do NOT commit real secrets)

# --- Database (required) ---
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- App state write protection (optional but recommended) ---
# If set, POST /api/state requires header x-bd-write-key with this value.
STATE_WRITE_KEY=

# --- Email / SMTP (optional; required only for outbound email) ---
# Example for Office 365: smtp.office365.com / 587 / false
# Example for Resend:     smtp.resend.com     / 587 / false (user=resend, password=API key)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=PIRAMID BD <no-reply@yourdomain.com>
